<%
const announcementEnabled = (typeof settings !== 'undefined' && settings.announcement_bar_enabled === '1');
const announcementText = (typeof settings !== 'undefined' && settings.announcement_bar_text) || '';
const announcementColor = (typeof settings !== 'undefined' && settings.announcement_bar_color) || '#C9A84C';
%>

<% if (announcementEnabled && announcementText) { %>
<div id="announcementBar" class="announcement-bar" style="background: <%= announcementColor %>;">
  <div class="announcement-bar__inner">
    <span><%= announcementText %></span>
    <button class="announcement-bar__close" onclick="dismissAnnouncement()" aria-label="Dismiss">&times;</button>
  </div>
</div>
<% } %>

<nav id="navbar" class="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__logo">STELLA BISTRO</a>

    <div class="navbar__links" id="navbarLinks">
      <a href="/" class="navbar__link <%= path === '/' ? 'active' : '' %>">Home</a>
      <a href="/menu" class="navbar__link <%= path === '/menu' ? 'active' : '' %>">Menu</a>
      <a href="/#story" class="navbar__link">About</a>
      <a href="/events" class="navbar__link <%= path === '/events' ? 'active' : '' %>">Events</a>
      <a href="/#location" class="navbar__link">Find Us</a>
      <a href="/#contact" class="navbar__link">Contact</a>
    </div>

    <div class="navbar__actions">
      <button class="navbar__cart-btn" id="cartToggle" aria-label="Open cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <span class="navbar__cart-badge" id="cartBadge">0</span>
      </a>
      <a href="/menu" class="navbar__order-btn">Order Now</a>
      <button class="navbar__hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div class="nav-overlay" id="navOverlay">
  <button class="nav-overlay__close" id="navOverlayClose">&times;</button>
  <div class="nav-overlay__links">
    <a href="/" class="nav-overlay__link">Home</a>
    <a href="/menu" class="nav-overlay__link">Menu</a>
    <a href="/#story" class="nav-overlay__link">About</a>
    <a href="/events" class="nav-overlay__link">Events</a>
    <a href="/#location" class="nav-overlay__link">Find Us</a>
    <a href="/#contact" class="nav-overlay__link">Contact</a>
    <a href="/menu" class="nav-overlay__link nav-overlay__link--action">Order Now</a>
  </div>
</div>

<!-- Cart Sidebar -->
<div class="cart-sidebar" id="cartSidebar">
  <div class="cart-sidebar__overlay" id="cartOverlay"></div>
  <div class="cart-sidebar__panel">
    <div class="cart-sidebar__header">
      <h3>Your Order</h3>
      <span class="cart-sidebar__count" id="cartCount">0 items</span>
      <button class="cart-sidebar__close" id="cartClose">&times;</button>
    </div>
    <div class="cart-sidebar__items" id="cartItems">
      <div class="cart-sidebar__empty">
        <p>Your cart is empty. Start adding dishes 🍽️</p>
        <a href="/menu" class="btn btn--outline" style="margin-top:1rem;">Browse Menu</a>
      </div>
    </div>
    <div class="cart-sidebar__footer" id="cartFooter" style="display:none;">
      <div class="cart-sidebar__row"><span>Subtotal</span><span id="cartSubtotal">Rs. 0</span></div>
      <div class="cart-sidebar__row"><span>Delivery Fee</span><span id="cartDeliveryFee">Rs. 0</span></div>
      <div class="cart-sidebar__row cart-sidebar__row--total"><span>Total</span><span id="cartTotal">Rs. 0</span></div>
      <a href="/checkout" class="btn btn--gold cart-sidebar__checkout">Checkout →</a>
    </div>
  </div>
</div>

<script src="/js/cart.js"></script>
