<footer class="footer">
  <div class="footer__hr"></div>
  <div class="footer__inner">
    <div class="footer__col">
      <div class="footer__logo">STELLA BISTRO</div>
      <p class="footer__tagline"><%= (typeof settings !== 'undefined' && settings.hero_tagline) || 'Where Every Plate Tells a Story' %></p>
      <div class="footer__social">
        <% if (typeof settings !== 'undefined' && settings.instagram_url) { %>
          <a href="<%= settings.instagram_url %>" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        <% } %>
        <% if (typeof settings !== 'undefined' && settings.facebook_url) { %>
          <a href="<%= settings.facebook_url %>" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        <% } %>
        <% if (typeof settings !== 'undefined' && settings.whatsapp_number) { %>
          <a href="https://wa.me/<%= settings.whatsapp_number %>" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        <% } %>
      </div>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Quick Links</h4>
      <a href="/" class="footer__link">Home</a>
      <a href="/menu" class="footer__link">Menu</a>
      <a href="/#story" class="footer__link">About</a>
      <a href="/events" class="footer__link">Events</a>
      <a href="/#gallery" class="footer__link">Gallery</a>
      <a href="/#contact" class="footer__link">Contact</a>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Opening Hours</h4>
      <% if (typeof hours !== 'undefined' && hours.length > 0) { %>
        <% hours.forEach(h => { %>
          <div class="footer__hours-row">
            <span class="footer__hours-day"><%= h.day_name %></span>
            <span class="footer__hours-time"><%= h.is_closed ? 'Closed' : (h.open_time + ' – ' + h.close_time) %></span>
          </div>
        <% }); %>
      <% } %>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Contact</h4>
      <% if (typeof settings !== 'undefined' && settings.address) { %>
        <p class="footer__contact-item"><%= settings.address %></p>
      <% } %>
      <% if (typeof settings !== 'undefined' && settings.phone) { %>
        <a href="tel:<%= settings.phone.replace(/[^0-9+]/g,'') %>" class="footer__contact-item footer__link"><%= settings.phone %></a>
      <% } %>
      <% if (typeof settings !== 'undefined' && settings.email) { %>
        <a href="mailto:<%= settings.email %>" class="footer__contact-item footer__link"><%= settings.email %></a>
      <% } %>
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; 2025 Stella Bistro. All rights reserved.</p>
  </div>
</footer>
