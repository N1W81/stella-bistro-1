<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="checkout-page">
    <div class="checkout-page__header">
      <h1>Checkout</h1>
    </div>

    <div class="checkout-layout" id="checkoutLayout">
      <!-- Order Summary -->
      <div class="checkout-summary">
        <h2 class="checkout-summary__title">Your Order</h2>
        <div id="checkoutItems"></div>
        <div class="checkout-summary__edit">
          <a href="/menu" class="checkout-summary__edit-link">← Edit Cart</a>
        </div>
        <div class="checkout-summary__totals">
          <div class="checkout-summary__row">
            <span>Subtotal</span>
            <span id="checkoutSubtotal">Rs. 0</span>
          </div>
          <div class="checkout-summary__row">
            <span>Delivery Fee</span>
            <span id="checkoutDeliveryFee">Rs. 0</span>
          </div>
          <div class="checkout-summary__row" id="checkoutDiscountRow" style="display:none;">
            <span>Discount</span>
            <span id="checkoutDiscount" style="color:#2ECC71;">-Rs. 0</span>
          </div>
          <div class="checkout-summary__row checkout-summary__row--promo">
            <input type="text" id="promoCode" placeholder="Promo code" class="input">
            <button id="applyPromo" class="btn btn--outline" style="padding:8px 16px;font-size:13px;">Apply</button>
          </div>
          <div class="checkout-summary__row checkout-summary__row--total">
            <span>Grand Total</span>
            <span id="checkoutTotal">Rs. 0</span>
          </div>
        </div>
      </div>

      <!-- Customer Form -->
      <form class="checkout-form" id="checkoutForm">
        <h2 class="checkout-form__title">Delivery Details</h2>

        <div class="form-group">
          <label for="customer_name">Full Name *</label>
          <input type="text" id="customer_name" name="customer_name" required class="input">
        </div>

        <div class="form-group">
          <label for="customer_phone">Phone Number * (+92)</label>
          <input type="tel" id="customer_phone" name="customer_phone" required pattern="^(\+92|0)[0-9\-]{10,13}" placeholder="03XX-XXXXXXX" class="input">
        </div>

        <div class="form-group">
          <label for="delivery_address">Delivery Address *</label>
          <textarea id="delivery_address" name="delivery_address" required placeholder="House/flat no., Street, Area" class="input" rows="3"></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="landmark">Nearest Landmark</label>
            <input type="text" id="landmark" name="landmark" class="input">
          </div>
          <div class="form-group">
            <label for="city">City *</label>
            <select id="city" name="city" class="input" required>
              <% if (typeof cities !== 'undefined' && cities.length > 0) { %>
                <% cities.forEach(c => { %>
                  <option value="<%= c %>"><%= c %></option>
                <% }); %>
              <% } else { %>
                <option value="Karachi">Karachi</option>
              <% } %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="special_instructions">Special Instructions</label>
          <textarea id="special_instructions" name="special_instructions" class="input" rows="2" placeholder="Any notes for the kitchen?"></textarea>
        </div>

        <h2 class="checkout-form__title" style="margin-top:2rem;">Payment Method</h2>
        <div class="payment-methods" id="paymentMethods"></div>

        <!-- Hidden fields -->
        <input type="hidden" name="payment_method" id="paymentMethodInput">
        <input type="hidden" name="transaction_id" id="transactionIdInput">
        <input type="hidden" name="payment_screenshot" id="paymentScreenshotInput">
        <input type="hidden" name="items_json" id="itemsJsonInput">
        <input type="hidden" name="subtotal" id="subtotalInput">
        <input type="hidden" name="delivery_fee" id="deliveryFeeInput">
        <input type="hidden" name="promo_code" id="promoCodeInput">
        <input type="hidden" name="promo_discount" id="promoDiscountInput">

        <div class="form-group" style="margin-top:1.5rem;">
          <label class="checkbox-label">
            <input type="checkbox" id="termsCheck" required>
            <span>I confirm my order details are correct</span>
          </label>
          <p class="form-hint">Estimated delivery: <span id="estimatedDelivery">30–45 minutes</span></p>
        </div>

        <button type="submit" class="btn btn--gold checkout-form__submit" id="placeOrderBtn">
          Place Order →
        </button>
      </form>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/cart.js"></script>
  <script src="/js/checkout.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
