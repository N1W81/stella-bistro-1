<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="confirmation-page">
    <div class="confirmation-page__inner">
      <div class="confirmation-page__checkmark">
        <svg viewBox="0 0 52 52" width="80" height="80">
          <circle cx="26" cy="26" r="25" fill="none" stroke="#C9A84C" stroke-width="2" class="check-circle"/>
          <path fill="none" stroke="#C9A84C" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" d="M14 27l7 7 16-16" class="check-path"/>
        </svg>
      </div>
      <h1 class="confirmation-page__heading">Order Placed! 🎉</h1>
      <p class="confirmation-page__order-number">Order <span class="mono">#<%= order.order_number %></span></p>

      <div class="confirmation-page__summary">
        <div class="confirmation-page__row">
          <span>Customer</span>
          <span><%= order.customer_name %></span>
        </div>
        <div class="confirmation-page__row">
          <span>Address</span>
          <span><%= order.delivery_address %></span>
        </div>
        <% if (order.landmark) { %>
        <div class="confirmation-page__row">
          <span>Landmark</span>
          <span><%= order.landmark %></span>
        </div>
        <% } %>
        <div class="confirmation-page__row">
          <span>Payment</span>
          <span><%= order.payment_method.charAt(0).toUpperCase() + order.payment_method.slice(1) %></span>
        </div>
        <div class="confirmation-page__row">
          <span>Total</span>
          <span class="mono gold">Rs. <%= Math.round(order.total) %></span>
        </div>
        <div class="confirmation-page__row">
          <span>Estimated Delivery</span>
          <span><%= (typeof settings !== 'undefined' && settings.estimated_delivery_time) || '30–45 minutes' %></span>
        </div>
      </div>

      <!-- Order Items (collapsible) -->
      <div class="confirmation-page__items">
        <button class="confirmation-page__toggle" onclick="toggleItems()">View Items ▾</button>
        <div id="orderItems" style="display:none;">
          <% if (order.items && order.items.length) { %>
            <% order.items.forEach(item => { %>
              <div class="confirmation-page__item">
                <span><%= item.name %> x<%= item.quantity %></span>
                <span>Rs. <%= Math.round(item.price * item.quantity) %></span>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

      <!-- WhatsApp -->
      <% if (typeof settings !== 'undefined' && settings.order_whatsapp_number) { %>
      <a href="https://wa.me/<%= settings.order_whatsapp_number %>?text=My+order+%23<%= order.order_number %>+is+placed" target="_blank" class="btn btn--gold" style="margin:1.5rem 0;">
        Get Updates on WhatsApp
      </a>
      <% } %>

      <!-- Status Tracker -->
      <div class="status-tracker">
        <h3>Track Order Status</h3>
        <div class="status-tracker__steps">
          <div class="status-step status-step--active" data-status="placed">
            <div class="status-step__dot"></div>
            <span>Placed ✓</span>
          </div>
          <div class="status-step" data-status="confirmed">
            <div class="status-step__dot"></div>
            <span>Confirmed</span>
          </div>
          <div class="status-step" data-status="out_for_delivery">
            <div class="status-step__dot"></div>
            <span>Out for Delivery</span>
          </div>
          <div class="status-step" data-status="delivered">
            <div class="status-step__dot"></div>
            <span>Delivered</span>
          </div>
        </div>
        <p class="status-tracker__current" id="currentStatus">Status: <%= order.status %></p>
      </div>

      <a href="/menu" class="btn btn--ghost" style="margin-top:1rem;">Order More →</a>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/order-confirmation.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
