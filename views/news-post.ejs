<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="post-page">
    <article class="post-article">
      <div class="post-article__hero" style="background-image: url('<%= post.thumbnail || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1200&q=80' %>');"></div>
      <div class="post-article__inner">
        <% if (post.category) { %><span class="post-article__tag"><%= post.category %></span><% } %>
        <h1 class="post-article__title"><%= post.title %></h1>
        <div class="post-article__meta">
          <span>By <%= post.author || 'Stella Bistro' %></span>
          <span><%= post.date %></span>
        </div>
        <div class="post-article__body">
          <%= post.body || post.excerpt || '' %>
        </div>
        <div class="post-article__share">
          <span>Share:</span>
          <a href="https://wa.me/?text=<%= encodeURIComponent(post.title + ' https://stellabistro.com/news/' + post.slug) %>" target="_blank" class="btn btn--outline" style="padding:6px 16px;font-size:13px;">WhatsApp</a>
          <button class="btn btn--outline" style="padding:6px 16px;font-size:13px;" onclick="navigator.clipboard.writeText(window.location.href);this.textContent='Copied!'">Copy Link</button>
        </div>
      </div>
    </article>

    <% if (typeof relatedPosts !== 'undefined' && relatedPosts.length > 0) { %>
    <section class="post-related">
      <h2 class="section__title">Related Posts</h2>
      <div class="post-related__grid">
        <% relatedPosts.forEach(rp => { %>
        <a href="/news/<%= rp.slug %>" class="news-card">
          <div class="news-card__image" style="background-image: url('<%= rp.thumbnail || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80' %>');"></div>
          <div class="news-card__body">
            <span class="news-card__date"><%= rp.date %></span>
            <h3><%= rp.title %></h3>
            <span class="news-card__more">Read More →</span>
          </div>
        </a>
        <% }); %>
      </div>
    </section>
    <% } %>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
