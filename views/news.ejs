<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="news-page">
    <div class="news-page__header">
      <h1>Latest from Stella</h1>
    </div>

    <div class="news-page__grid">
      <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
        <% posts.forEach(post => { %>
        <a href="/news/<%= post.slug %>" class="news-card">
          <div class="news-card__image" style="background-image: url('<%= post.thumbnail || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80' %>');">
            <% if (post.category) { %><span class="news-card__tag"><%= post.category %></span><% } %>
          </div>
          <div class="news-card__body">
            <span class="news-card__date"><%= post.date %></span>
            <h3><%= post.title %></h3>
            <p><%= (post.excerpt || '').substring(0, 150) %></p>
            <span class="news-card__more">Read More →</span>
          </div>
        </a>
        <% }); %>
      <% } else { %>
        <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">No news yet. Stay tuned!</p>
      <% } %>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/news?page=<%= i %>" class="pagination__link <%= i === currentPage ? 'pagination__link--active' : '' %>"><%= i %></a>
      <% } %>
    </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
