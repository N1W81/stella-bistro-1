<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Location & Contact</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/location/save" class="admin-form">
      <div class="form-group"><label>Address</label><textarea name="address" class="input" rows="2"><%= settings.address || '' %></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>Phone</label><input type="text" name="phone" class="input" value="<%= settings.phone || '' %>"></div>
        <div class="form-group"><label>WhatsApp Number</label><input type="text" name="whatsapp_number" class="input" value="<%= settings.whatsapp_number || '' %>"></div>
        <div class="form-group"><label>Email</label><input type="email" name="email" class="input" value="<%= settings.email || '' %>"></div>
      </div>
      <div class="form-group"><label>Google Maps Embed URL</label><input type="text" name="maps_embed_url" class="input" value="<%= settings.maps_embed_url || '' %>"></div>
      <div class="form-group"><label>Google Maps Directions URL</label><input type="text" name="maps_directions_url" class="input" value="<%= settings.maps_directions_url || '' %>"></div>
      <div class="form-row">
        <div class="form-group"><label>Instagram URL</label><input type="text" name="instagram_url" class="input" value="<%= settings.instagram_url || '' %>"></div>
        <div class="form-group"><label>Facebook URL</label><input type="text" name="facebook_url" class="input" value="<%= settings.facebook_url || '' %>"></div>
      </div>
      <div class="form-group"><label>Delivery Cities (comma separated)</label><input type="text" name="delivery_cities" class="input" value="<%= settings.delivery_cities || 'Karachi' %>"></div>
      <button class="btn btn--gold">Save</button>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
