<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Events</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <div class="admin-section">
      <h2>Add Event</h2>
      <form method="POST" action="/stella-control/events/add" enctype="multipart/form-data" class="admin-form">
        <div class="form-row">
          <div class="form-group"><label>Title *</label><input type="text" name="title" class="input" required></div>
          <div class="form-group"><label>Date *</label><input type="date" name="date" class="input" required></div>
          <div class="form-group"><label>Time</label><input type="time" name="time" class="input"></div>
        </div>
        <div class="form-group"><label>Description</label><textarea name="description" class="input" rows="3"></textarea></div>
        <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*" class="input"></div>
        <div class="form-group"><label><input type="checkbox" name="visible" value="1" checked> Visible</label></div>
        <button class="btn btn--gold">Add Event</button>
      </form>
    </div>
    <div class="admin-section">
      <h2>All Events</h2>
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead><tr><th>Image</th><th>Title</th><th>Date</th><th>Time</th><th>Visible</th><th>Actions</th></tr></thead>
          <tbody>
            <% events.forEach(e => { %>
            <tr>
              <td><% if(e.image_path) {%><img src="<%= e.image_path %>" style="width:60px;height:40px;object-fit:cover;border-radius:4px;"><%}%></td>
              <td><%= e.title %></td>
              <td><%= e.date %></td>
              <td><%= e.time || '-' %></td>
              <td><%= e.visible ? '✅' : '❌' %></td>
              <td>
                <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;" onclick="editEvent(<%= e.id %>)">Edit</button>
                <form method="POST" action="/stella-control/events/delete/<%= e.id %>" style="display:inline;" onsubmit="return confirm('Delete this event?')">
                  <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
