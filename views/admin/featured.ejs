<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Featured Dishes</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/featured/update">
      <div class="admin-section">
        <h2>Current Featured (4 max)</h2>
        <div class="featured-grid">
          <% for(let i = 0; i < 4; i++) { %>
          <div class="featured-slot">
            <h3>Slot <%= i+1 %></h3>
            <select name="featured_ids" class="input">
              <option value="">— Select —</option>
              <% [].concat(available || []).concat(featured || []).forEach(item => { %>
                <option value="<%= item.id %>" <%= featured[i] && featured[i].id === item.id ? 'selected' : '' %>><%= item.name %></option>
              <% }); %>
            </select>
          </div>
          <% }); %>
        </div>
        <button class="btn btn--gold">Save Featured Dishes</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
