<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Promo Codes</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
    <div class="admin-content">
      <div class="admin-section">
        <h2>Add Promo Code</h2>
        <form method="POST" action="/stella-control/promos/add" class="admin-form">
          <div class="form-row">
            <div class="form-group"><label>Code</label><input type="text" name="code" class="input" required placeholder="STELLA20"></div>
            <div class="form-group"><label>Type</label><select name="discount_type" class="input"><option value="percentage">Percentage %</option><option value="fixed">Fixed Rs.</option></select></div>
            <div class="form-group"><label>Value</label><input type="number" name="discount_value" class="input" step="0.01" required></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Min Order</label><input type="number" name="min_order" class="input" value="0"></div>
            <div class="form-group"><label>Expiry</label><input type="date" name="expiry_date" class="input"></div>
            <div class="form-group"><label>Usage Limit</label><input type="number" name="usage_limit" class="input" placeholder="Unlimited"></div>
            <div class="form-group"><label><input type="checkbox" name="active" value="1" checked> Active</label></div>
          </div>
          <button class="btn btn--gold">Add Promo</button>
        </form>
      </div>
      <div class="admin-section">
        <h2>Promo Codes</h2>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead><tr><th>Code</th><th>Type</th><th>Value</th><th>Min Order</th><th>Expiry</th><th>Usage</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              <% promos.forEach(p => { %>
              <tr>
                <td class="mono"><%= p.code %></td>
                <td><%= p.discount_type === 'percentage' ? '%' : 'Rs.' %></td>
                <td><%= p.discount_value %></td>
                <td><%= p.min_order > 0 ? 'Rs. ' + p.min_order : '-' %></td>
                <td><%= p.expiry_date || '-' %></td>
                <td><%= p.times_used %><%= p.usage_limit ? '/' + p.usage_limit : '' %></td>
                <td><%= p.active ? '✅' : '❌' %></td>
                <td>
                  <form method="POST" action="/stella-control/promos/delete/<%= p.id %>" onsubmit="return confirm('Delete this promo?')">
                    <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <script src="/js/admin/admin-main.js"></script>
</body>
</html>
