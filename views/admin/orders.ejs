<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-topbar__hamburger" id="sidebarToggle">☰</button>
      <h1 class="admin-topbar__title">Orders</h1>
      <div class="admin-topbar__actions">
        <span class="admin-topbar__user"><%= adminUsername %></span>
        <a href="/stella-control/logout" class="admin-topbar__logout">Logout</a>
      </div>
    </header>

    <div class="admin-content">
      <!-- Stats Bar -->
      <div class="order-stats">
        <span>Today: <strong><%= todayStats.count || 0 %></strong> orders</span>
        <span>Revenue: <strong>Rs. <%= Math.round(todayStats.revenue || 0) %></strong></span>
        <span>Pending: <strong style="color:#DC143C;"><%= pendingStat.count || 0 %></strong></span>
        <span>Delivered: <strong style="color:#2ECC71;"><%= deliveredStat.count || 0 %></strong></span>
      </div>

      <!-- Filters -->
      <div class="order-filters">
        <div class="order-filters__tabs">
          <a href="/stella-control/orders" class="order-filter-tab <%= !currentStatus || currentStatus === 'all' ? 'active' : '' %>">All</a>
          <a href="/stella-control/orders?status=today" class="order-filter-tab <%= currentStatus === 'today' ? 'active' : '' %>">Today</a>
          <a href="/stella-control/orders?status=week" class="order-filter-tab <%= currentStatus === 'week' ? 'active' : '' %>">This Week</a>
          <a href="/stella-control/orders?status=pending" class="order-filter-tab <%= currentStatus === 'pending' ? 'active' : '' %>">Pending</a>
          <a href="/stella-control/orders?status=completed" class="order-filter-tab <%= currentStatus === 'completed' ? 'active' : '' %>">Delivered</a>
          <a href="/stella-control/orders?status=cancelled" class="order-filter-tab <%= currentStatus === 'cancelled' ? 'active' : '' %>">Cancelled</a>
        </div>
        <div class="order-filters__search">
          <input type="text" id="orderSearch" placeholder="Search order#, name, phone..." class="input" value="<%= search %>" onkeyup="filterOrders()">
          <a href="/stella-control/orders/export" class="btn btn--outline" style="padding:6px 12px;font-size:12px;">Export CSV</a>
        </div>
      </div>

      <!-- Kanban Board -->
      <div class="kanban" id="kanbanBoard">
        <div class="kanban__column">
          <div class="kanban__column-header kanban__column-header--pending">🔴 PENDING</div>
          <div class="kanban__cards" id="pendingOrders">
            <% orders.filter(o => o.status === 'pending').forEach(o => { %>
              <%- include('_orderCard', { order: o }) %>
            <% }); %>
            <% if (orders.filter(o => o.status === 'pending').length === 0) { %>
              <div class="kanban__empty">No pending orders</div>
            <% } %>
          </div>
        </div>

        <div class="kanban__column">
          <div class="kanban__column-header kanban__column-header--progress">🟡 IN PROGRESS</div>
          <div class="kanban__cards" id="progressOrders">
            <% orders.filter(o => o.status === 'in_progress').forEach(o => { %>
              <%- include('_orderCard', { order: o }) %>
            <% }); %>
            <% if (orders.filter(o => o.status === 'in_progress').length === 0) { %>
              <div class="kanban__empty">No orders in progress</div>
            <% } %>
          </div>
        </div>

        <div class="kanban__column">
          <div class="kanban__column-header kanban__column-header--completed">🟢 COMPLETED</div>
          <div class="kanban__cards" id="completedOrders">
            <% orders.filter(o => o.status === 'completed').forEach(o => { %>
              <%- include('_orderCard', { order: o }) %>
            <% }); %>
            <% if (orders.filter(o => o.status === 'completed').length === 0) { %>
              <div class="kanban__empty">No completed orders</div>
            <% } %>
          </div>
        </div>

        <div class="kanban__column">
          <div class="kanban__column-header kanban__column-header--cancelled">❌ CANCELLED</div>
          <div class="kanban__cards" id="cancelledOrders">
            <% orders.filter(o => o.status === 'cancelled').forEach(o => { %>
              <%- include('_orderCard', { order: o }) %>
            <% }); %>
            <% if (orders.filter(o => o.status === 'cancelled').length === 0) { %>
              <div class="kanban__empty">No cancelled orders</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/admin/admin-main.js"></script>
  <script src="/js/admin/orders.js"></script>
</body>
</html>
