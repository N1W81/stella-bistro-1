<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Testimonials</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <div class="admin-section">
      <h2>Add Testimonial</h2>
      <form method="POST" action="/stella-control/testimonials/add" class="admin-form">
        <div class="form-row">
          <div class="form-group"><label>Reviewer Name *</label><input type="text" name="reviewer_name" class="input" required></div>
          <div class="form-group"><label>Rating</label><select name="rating" class="input"><% for(let i=1;i<=5;i++){%><option value="<%=i%>"><%=i%> ★</option><%}%></select></div>
          <div class="form-group"><label>Date</label><input type="date" name="review_date" class="input"></div>
        </div>
        <div class="form-group"><label>Review Text *</label><textarea name="review_text" class="input" rows="3" required></textarea></div>
        <div class="form-group"><label><input type="checkbox" name="visible" value="1" checked> Visible</label></div>
        <button class="btn btn--gold">Add Testimonial</button>
      </form>
    </div>
    <div class="admin-section">
      <h2>All Testimonials</h2>
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead><tr><th>Name</th><th>Rating</th><th>Review</th><th>Date</th><th>Visible</th><th>Actions</th></tr></thead>
          <tbody>
            <% testimonials.forEach(t => { %>
            <tr>
              <td><%= t.reviewer_name %></td>
              <td><% for(let i=0;i<t.rating;i++){%>★<%}%></td>
              <td style="max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= t.review_text %></td>
              <td><%= t.review_date %></td>
              <td><%= t.visible ? '✅' : '❌' %></td>
              <td>
                <form method="POST" action="/stella-control/testimonials/delete/<%= t.id %>" style="display:inline;" onsubmit="return confirm('Delete?')">
                  <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
