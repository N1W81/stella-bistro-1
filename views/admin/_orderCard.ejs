<div class="order-card" data-order-id="<%= order.id %>" data-order-number="<%= order.order_number %>" data-status="<%= order.status %>">
  <div class="order-card__header">
    <span class="order-card__number mono">#<%= order.order_number %></span>
    <span class="order-card__time"><%= new Date(order.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
  </div>
  <div class="order-card__divider"></div>
  <div class="order-card__info">
    <div class="order-card__customer">👤 <%= order.customer_name %></div>
    <div class="order-card__phone">📱 <%= order.customer_phone %>
      <button class="copy-btn" onclick="copyText('<%= order.customer_phone %>')" title="Copy phone">📋</button>
    </div>
    <div class="order-card__address">📍 <%= order.delivery_address %></div>
  </div>
  <div class="order-card__divider"></div>
  <div class="order-card__items">
    <% if (order.items && order.items.length > 0) { %>
      <% order.items.forEach(item => { %>
        <div class="order-card__item">• <%= item.name %> x<%= item.quantity %></div>
      <% }); %>
    <% } %>
  </div>
  <div class="order-card__divider"></div>
  <div class="order-card__pricing">
    <div class="order-card__row"><span>Subtotal:</span><span>Rs. <%= Math.round(order.subtotal) %></span></div>
    <div class="order-card__row"><span>Delivery:</span><span>Rs. <%= Math.round(order.delivery_fee) %></span></div>
    <div class="order-card__row order-card__row--total"><span>TOTAL:</span><span>Rs. <%= Math.round(order.total) %></span></div>
  </div>
  <div class="order-card__divider"></div>
  <div class="order-card__payment">
    <div class="order-card__payment-method">💳 <%= order.payment_method.charAt(0).toUpperCase() + order.payment_method.slice(1) %></div>
    <% if (order.transaction_id) { %>
      <div class="order-card__txn">TXN: <%= order.transaction_id %>
        <button class="copy-btn" onclick="copyText('<%= order.transaction_id %>')" title="Copy TXN">📋</button>
      </div>
    <% } %>
    <% if (order.payment_screenshot) { %>
      <div class="order-card__screenshot">
        <a href="<%= order.payment_screenshot %>" target="_blank" class="btn-link">📎 View Screenshot</a>
      </div>
    <% } %>
    <div class="order-card__verify">
      <label class="checkbox-label">
        <input type="checkbox" <%= order.payment_verified ? 'checked' : '' %> onchange="togglePaymentVerify(<%= order.id %>, this.checked)">
        <span>Payment Verified</span>
      </label>
    </div>
  </div>
  <% if (order.special_instructions) { %>
    <div class="order-card__divider"></div>
    <div class="order-card__special">📝 <%= order.special_instructions %></div>
  <% } %>
  <div class="order-card__divider"></div>
  <div class="order-card__actions">
    <% if (order.status === 'pending') { %>
      <button class="btn btn--gold" style="padding:6px 12px;font-size:12px;" onclick="updateStatus(<%= order.id %>, 'in_progress')">✓ Confirm</button>
      <button class="btn btn--danger" style="padding:6px 12px;font-size:12px;" onclick="cancelOrder(<%= order.id %>)">✕ Cancel</button>
    <% } else if (order.status === 'in_progress') { %>
      <button class="btn btn--gold" style="padding:6px 12px;font-size:12px;" onclick="updateStatus(<%= order.id %>, 'completed')">🚚 Mark Delivered</button>
      <button class="btn btn--danger" style="padding:6px 12px;font-size:12px;" onclick="cancelOrder(<%= order.id %>)">✕ Cancel</button>
    <% } %>
  </div>
</div>
