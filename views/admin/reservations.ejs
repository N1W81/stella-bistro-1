<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Reservations</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a><a href="/stella-control/reservations/export" class="btn btn--outline" style="padding:6px 12px;font-size:12px;">Export CSV</a></div></header>
  <div class="admin-content">
    <div class="order-filters">
      <a href="/stella-control/reservations" class="order-filter-tab <%= !status ? 'active' : '' %>">All</a>
      <a href="/stella-control/reservations?status=pending" class="order-filter-tab <%= status === 'pending' ? 'active' : '' %>">Pending</a>
      <a href="/stella-control/reservations?status=confirmed" class="order-filter-tab <%= status === 'confirmed' ? 'active' : '' %>">Confirmed</a>
      <a href="/stella-control/reservations?status=cancelled" class="order-filter-tab <%= status === 'cancelled' ? 'active' : '' %>">Cancelled</a>
    </div>
    <div class="admin-table-wrapper">
      <table class="admin-table">
        <thead><tr><th>#</th><th>Date</th><th>Time</th><th>Name</th><th>Phone</th><th>Guests</th><th>Occasion</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% reservations.forEach(r => { %>
          <tr>
            <td><%= r.id %></td>
            <td><%= r.date %></td>
            <td><%= r.time %></td>
            <td><%= r.name %></td>
            <td><%= r.phone %></td>
            <td><%= r.guests %></td>
            <td><%= r.occasion || '-' %></td>
            <td><span class="status-badge status-badge--<%= r.status %>"><%= r.status %></span></td>
            <td>
              <form method="POST" action="/stella-control/reservations/update/<%= r.id %>" style="display:flex;gap:4px;">
                <select name="status" class="input" style="width:auto;font-size:12px;padding:4px 8px;">
                  <option value="pending" <%= r.status === 'pending' ? 'selected' : '' %>>Pending</option>
                  <option value="confirmed" <%= r.status === 'confirmed' ? 'selected' : '' %>>Confirmed</option>
                  <option value="cancelled" <%= r.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                </select>
                <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;">Update</button>
              </form>
            </td>
          </tr>
          <% if (r.special_requests || r.admin_notes) { %>
          <tr class="admin-table__detail-row">
            <td colspan="9">
              <% if(r.special_requests) { %><div><strong>Requests:</strong> <%= r.special_requests %></div><% } %>
              <form method="POST" action="/stella-control/reservations/update/<%= r.id %>" style="display:flex;gap:4px;margin-top:4px;">
                <input type="hidden" name="status" value="<%= r.status %>">
                <input type="text" name="admin_notes" class="input" value="<%= r.admin_notes || '' %>" placeholder="Admin notes" style="font-size:12px;">
                <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;">Save Notes</button>
              </form>
            </td>
          </tr>
          <% } %>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
