<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-topbar__hamburger" id="sidebarToggle">☰</button>
      <h1 class="admin-topbar__title">Dashboard</h1>
      <div class="admin-topbar__actions">
        <span class="admin-topbar__user"><%= adminUsername %></span>
        <a href="/stella-control/logout" class="admin-topbar__logout">Logout</a>
      </div>
    </header>

    <div class="admin-content">
      <!-- Stats Cards -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-card__value"><%= ordersToday.count || 0 %></div>
          <div class="stat-card__label">Today's Orders</div>
          <div class="stat-card__sub">Rs. <%= Math.round(ordersToday.revenue || 0) %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value" style="color:<%= (pendingOrders.count || 0) > 0 ? '#DC143C' : '#2ECC71' %>"><%= pendingOrders.count || 0 %></div>
          <div class="stat-card__label">Pending Orders</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value">Rs. <%= Math.round(weekRevenue.revenue || 0) %></div>
          <div class="stat-card__label">This Week's Revenue</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value"><%= totalItems.count || 0 %></div>
          <div class="stat-card__label">Total Menu Items</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value"><%= upcomingEvents.count || 0 %></div>
          <div class="stat-card__label">Upcoming Events</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__value"><%= newReservations.count || 0 %></div>
          <div class="stat-card__label">New Reservations (24h)</div>
        </div>
      </div>

      <!-- Recent Orders -->
      <div class="admin-section">
        <div class="admin-section__header">
          <h2>Recent Orders</h2>
          <a href="/stella-control/orders" class="btn btn--outline" style="padding:6px 14px;font-size:13px;">View All</a>
        </div>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead><tr><th>Order#</th><th>Customer</th><th>Total</th><th>Status</th><th>Time</th><th></th></tr></thead>
            <tbody>
              <% if (typeof recentOrders !== 'undefined' && recentOrders.length > 0) { %>
                <% recentOrders.forEach(o => { %>
                <tr>
                  <td class="mono"><%= o.order_number %></td>
                  <td><%= o.customer_name %></td>
                  <td>Rs. <%= Math.round(o.total) %></td>
                  <td><span class="status-badge status-badge--<%= o.status %>"><%= o.status %></span></td>
                  <td><%= new Date(o.created_at).toLocaleTimeString() %></td>
                  <td><a href="/stella-control/orders" class="btn-link">View</a></td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="6" style="text-align:center;color:var(--text-secondary);">No orders yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Recent Reservations -->
      <div class="admin-section">
        <div class="admin-section__header">
          <h2>Recent Reservations</h2>
          <a href="/stella-control/reservations" class="btn btn--outline" style="padding:6px 14px;font-size:13px;">View All</a>
        </div>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead><tr><th>Name</th><th>Date</th><th>Time</th><th>Guests</th><th>Status</th></tr></thead>
            <tbody>
              <% if (typeof recentReservations !== 'undefined' && recentReservations.length > 0) { %>
                <% recentReservations.forEach(r => { %>
                <tr>
                  <td><%= r.name %></td>
                  <td><%= r.date %></td>
                  <td><%= r.time %></td>
                  <td><%= r.guests %></td>
                  <td><span class="status-badge status-badge--<%= r.status %>"><%= r.status %></span></td>
                </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="5" style="text-align:center;color:var(--text-secondary);">No reservations yet</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="admin-section">
        <h2>Quick Actions</h2>
        <div class="quick-actions">
          <a href="/stella-control/menu" class="btn btn--gold">+ Add Menu Item</a>
          <a href="/stella-control/events" class="btn btn--outline">+ Add Event</a>
          <a href="/stella-control/news" class="btn btn--outline">+ Add News Post</a>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/admin/admin-main.js"></script>
</body>
</html>
