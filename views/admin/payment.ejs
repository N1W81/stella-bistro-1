<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Payment Settings</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/payment/save" class="admin-form">
      <div class="admin-section"><h2>JazzCash</h2><div class="form-row"><div class="form-group"><label>Mobile Number</label><input type="text" name="jazzcash_number" class="input" value="<%= settings.jazzcash_number || '' %>"></div><div class="form-group"><label>Account Name</label><input type="text" name="jazzcash_name" class="input" value="<%= settings.jazzcash_name || '' %>"></div><div class="form-group"><label><input type="checkbox" name="jazzcash_enabled" value="1" <%= settings.jazzcash_enabled === '1' ? 'checked' : '' %>> Enabled</label></div></div></div>
      <div class="admin-section"><h2>EasyPaisa</h2><div class="form-row"><div class="form-group"><label>Mobile Number</label><input type="text" name="easypaisa_number" class="input" value="<%= settings.easypaisa_number || '' %>"></div><div class="form-group"><label>Account Name</label><input type="text" name="easypaisa_name" class="input" value="<%= settings.easypaisa_name || '' %>"></div><div class="form-group"><label><input type="checkbox" name="easypaisa_enabled" value="1" <%= settings.easypaisa_enabled === '1' ? 'checked' : '' %>> Enabled</label></div></div></div>
      <div class="admin-section"><h2>Meezan Bank</h2><div class="form-group"><label>Bank Details</label><textarea name="meezan_details" class="input" rows="3"><%= settings.meezan_details || '' %></textarea></div><div class="form-group"><label><input type="checkbox" name="meezan_enabled" value="1" <%= settings.meezan_enabled === '1' ? 'checked' : '' %>> Enabled</label></div></div>
      <div class="admin-section"><h2>HBL / Other Bank</h2><div class="form-group"><label>Bank Details</label><textarea name="hbl_details" class="input" rows="3"><%= settings.hbl_details || '' %></textarea></div><div class="form-group"><label><input type="checkbox" name="hbl_enabled" value="1" <%= settings.hbl_enabled === '1' ? 'checked' : '' %>> Enabled</label></div></div>
      <div class="admin-section"><h2>Cash on Delivery</h2><div class="form-row"><div class="form-group"><label><input type="checkbox" name="cod_enabled" value="1" <%= settings.cod_enabled === '1' ? 'checked' : '' %>> Enabled</label></div><div class="form-group"><label>Max COD Amount (0 = no limit)</label><input type="number" name="cod_max_amount" class="input" value="<%= settings.cod_max_amount || 0 %>"></div></div></div>
      <div class="admin-section"><h2>Delivery Settings</h2><div class="form-row"><div class="form-group"><label>Delivery Fee (PKR)</label><input type="number" name="delivery_fee" class="input" value="<%= settings.delivery_fee || 100 %>" step="0.01"></div><div class="form-group"><label>Free Delivery Above</label><input type="number" name="free_delivery_above" class="input" value="<%= settings.free_delivery_above || 0 %>"></div></div><div class="form-row"><div class="form-group"><label>Min Order Amount</label><input type="number" name="min_order" class="input" value="<%= settings.min_order || 500 %>"></div><div class="form-group"><label>Est. Delivery Time</label><input type="text" name="estimated_delivery_time" class="input" value="<%= settings.estimated_delivery_time || '30–45 minutes' %>"></div><div class="form-group"><label>WhatsApp Notification #</label><input type="text" name="order_whatsapp_number" class="input" value="<%= settings.order_whatsapp_number || '' %>"></div></div></div>
      <button class="btn btn--gold">Save All Settings</button>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
