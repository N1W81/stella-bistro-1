<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Announcements</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/announcements/save" class="admin-form">
      <div class="admin-section">
        <h2>Announcement Bar</h2>
        <div class="form-row">
          <div class="form-group"><label><input type="checkbox" name="announcement_bar_enabled" value="1" <%= settings.announcement_bar_enabled === '1' ? 'checked' : '' %>> Enable Announcement Bar</label></div>
          <div class="form-group"><label>Background Color</label><select name="announcement_bar_color" class="input"><option value="#C9A84C" <%= settings.announcement_bar_color === '#C9A84C' ? 'selected' : '' %>>Gold</option><option value="#DC143C" <%= settings.announcement_bar_color === '#DC143C' ? 'selected' : '' %>>Red</option><option value="#2ECC71" <%= settings.announcement_bar_color === '#2ECC71' ? 'selected' : '' %>>Green</option></select></div>
        </div>
        <div class="form-group"><label>Message</label><input type="text" name="announcement_bar_text" class="input" value="<%= settings.announcement_bar_text || '' %>" placeholder="Your announcement here"></div>
      </div>
      <div class="admin-section">
        <h2>Popup Modal Announcement</h2>
        <div class="form-group"><label><input type="checkbox" name="popup_enabled" value="1" <%= settings.popup_enabled === '1' ? 'checked' : '' %>> Enable Popup</label></div>
        <div class="form-group"><label>Title</label><input type="text" name="popup_title" class="input" value="<%= settings.popup_title || '' %>"></div>
        <div class="form-group"><label>Body</label><textarea name="popup_body" class="input" rows="3"><%= settings.popup_body || '' %></textarea></div>
        <div class="form-row">
          <div class="form-group"><label>Button Text</label><input type="text" name="popup_button_text" class="input" value="<%= settings.popup_button_text || '' %>"></div>
          <div class="form-group"><label>Button Link</label><input type="text" name="popup_button_link" class="input" value="<%= settings.popup_button_link || '' %>"></div>
        </div>
        <div class="form-group"><label>Expiry Date</label><input type="date" name="popup_expiry" class="input" value="<%= settings.popup_expiry || '' %>"></div>
      </div>
      <button class="btn btn--gold">Save</button>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
