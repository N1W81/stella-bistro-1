<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-topbar__hamburger" id="sidebarToggle">☰</button>
      <h1 class="admin-topbar__title">Analytics</h1>
      <div class="admin-topbar__actions">
        <span class="admin-topbar__user"><%= adminUsername %></span>
        <a href="/stella-control/logout" class="admin-topbar__logout">Logout</a>
      </div>
    </header>
    <div class="admin-content">
      <div class="analytics-controls">
        <select id="dateRange" class="input" style="width:auto;" onchange="loadAnalytics()">
          <option value="7">Last 7 Days</option>
          <option value="30" selected>Last 30 Days</option>
          <option value="90">Last 3 Months</option>
          <option value="custom">Custom</option>
        </select>
        <input type="date" id="dateFrom" class="input" style="width:auto;display:none;" onchange="loadAnalytics()">
        <input type="date" id="dateTo" class="input" style="width:auto;display:none;" onchange="loadAnalytics()">
      </div>

      <div class="stats-grid" id="analyticsSummary"></div>

      <div class="charts-grid">
        <div class="chart-card"><h3>Revenue Over Time</h3><canvas id="revenueChart"></canvas></div>
        <div class="chart-card"><h3>Orders by Status</h3><canvas id="statusChart"></canvas></div>
        <div class="chart-card"><h3>Top Items</h3><canvas id="topItemsChart"></canvas></div>
        <div class="chart-card"><h3>Payment Methods</h3><canvas id="paymentChart"></canvas></div>
        <div class="chart-card"><h3>Orders by Hour</h3><canvas id="hourlyChart"></canvas></div>
        <div class="chart-card"><h3>Revenue by Category</h3><canvas id="categoryChart"></canvas></div>
      </div>
    </div>
  </div>
  <script src="/js/admin/admin-main.js"></script>
  <script src="/js/admin/analytics.js"></script>
</body>
</html>
