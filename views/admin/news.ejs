<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>News Manager</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <div class="admin-section">
      <h2>Add News Post</h2>
      <form method="POST" action="/stella-control/news/add" enctype="multipart/form-data" class="admin-form">
        <div class="form-row">
          <div class="form-group"><label>Title *</label><input type="text" name="title" class="input" required></div>
          <div class="form-group"><label>Slug</label><input type="text" name="slug" class="input" placeholder="Auto-generated"></div>
        </div>
        <div class="form-row">
          <div class="form-group"><label>Author</label><input type="text" name="author" class="input" value="Stella Bistro"></div>
          <div class="form-group"><label>Category</label><input type="text" name="category" class="input" placeholder="e.g. Events, Food"></div>
          <div class="form-group"><label>Date</label><input type="date" name="date" class="input"></div>
        </div>
        <div class="form-group"><label>Thumbnail</label><input type="file" name="thumbnail" accept="image/*" class="input"></div>
        <div class="form-group"><label>Excerpt</label><textarea name="excerpt" class="input" rows="2"></textarea></div>
        <div class="form-group"><label>Body (HTML)</label><textarea name="body" class="input" rows="8" style="font-family:monospace;"></textarea></div>
        <div class="form-group"><label><input type="checkbox" name="published" value="1"> Published</label></div>
        <button class="btn btn--gold">Add Post</button>
      </form>
    </div>
    <div class="admin-section">
      <h2>All Posts</h2>
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead><tr><th>Thumb</th><th>Title</th><th>Date</th><th>Slug</th><th>Published</th><th>Actions</th></tr></thead>
          <tbody>
            <% posts.forEach(p => { %>
            <tr>
              <td><% if(p.thumbnail) {%><img src="<%= p.thumbnail %>" style="width:60px;height:40px;object-fit:cover;border-radius:4px;"><%}%></td>
              <td><%= p.title %></td>
              <td><%= p.date %></td>
              <td class="mono"><%= p.slug %></td>
              <td><%= p.published ? '✅' : '❌' %></td>
              <td>
                <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;">Edit</button>
                <form method="POST" action="/stella-control/news/delete/<%= p.id %>" style="display:inline;" onsubmit="return confirm('Delete this post?')">
                  <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                </form>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
