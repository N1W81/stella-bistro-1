<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-topbar__hamburger" id="sidebarToggle">☰</button>
      <h1 class="admin-topbar__title">Menu Manager</h1>
      <div class="admin-topbar__actions">
        <span class="admin-topbar__user"><%= adminUsername %></span>
        <a href="/stella-control/logout" class="admin-topbar__logout">Logout</a>
      </div>
    </header>

    <div class="admin-content">
      <!-- Add Category -->
      <div class="admin-section">
        <h2>Categories</h2>
        <form method="POST" action="/stella-control/menu/category/add" class="inline-form">
          <input type="text" name="name" placeholder="New category name" class="input" required>
          <button class="btn btn--gold" style="padding:8px 16px;">Add Category</button>
        </form>
        <div class="category-list">
          <% categories.forEach(cat => { %>
          <div class="category-item">
            <form method="POST" action="/stella-control/menu/category/update" class="inline-form">
              <input type="hidden" name="id" value="<%= cat.id %>">
              <input type="text" name="name" value="<%= cat.name %>" class="input" style="width:auto;">
              <input type="number" name="display_order" value="<%= cat.display_order %>" class="input" style="width:60px;" placeholder="Order">
              <button class="btn btn--outline" style="padding:6px 12px;">Save</button>
            </form>
            <form method="POST" action="/stella-control/menu/category/delete" style="display:inline;" onsubmit="return confirm('Delete this category and all its items?')">
              <input type="hidden" name="id" value="<%= cat.id %>">
              <button class="btn btn--danger" style="padding:6px 12px;">Delete</button>
            </form>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Add Item -->
      <div class="admin-section">
        <h2>Add Menu Item</h2>
        <form method="POST" action="/stella-control/menu/item/add" enctype="multipart/form-data" class="admin-form">
          <div class="form-row">
            <div class="form-group">
              <label>Name *</label>
              <input type="text" name="name" class="input" required>
            </div>
            <div class="form-group">
              <label>Category *</label>
              <select name="category_id" class="input" required>
                <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Description</label>
            <textarea name="description" class="input" rows="2"></textarea>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Base Price (PKR) *</label>
              <input type="number" name="base_price" class="input" step="0.01" required>
            </div>
            <div class="form-group">
              <label>Original Price (PKR)</label>
              <input type="number" name="original_price" class="input" step="0.01">
            </div>
          </div>
          <div class="form-group">
            <label>Image</label>
            <input type="file" name="image" accept="image/jpeg,image/png,image/webp" class="input">
          </div>
          <div class="form-group">
            <label>Tags</label>
            <div class="tag-checkboxes">
              <label><input type="checkbox" name="tags" value="Spicy 🌶"> Spicy 🌶</label>
              <label><input type="checkbox" name="tags" value="Vegetarian 🌱"> Vegetarian 🌱</label>
              <label><input type="checkbox" name="tags" value="Chef's Special ⭐"> Chef's Special ⭐</label>
              <label><input type="checkbox" name="tags" value="Bestseller 🔥"> Bestseller 🔥</label>
              <label><input type="checkbox" name="tags" value="New ✨"> New ✨</label>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Display Order</label>
              <input type="number" name="display_order" class="input" value="0">
            </div>
            <div class="form-group">
              <label>Kitchen Notes</label>
              <input type="text" name="kitchen_notes" class="input">
            </div>
          </div>
          <button class="btn btn--gold">Add Item</button>
        </form>
      </div>

      <!-- Items by Category -->
      <% menuData.forEach(cat => { %>
      <div class="admin-section">
        <h2><%= cat.name %> (<%= cat.items.length %> items)</h2>
        <div class="admin-table-wrapper">
          <table class="admin-table">
            <thead><tr><th>Image</th><th>Name</th><th>Price</th><th>Discount</th><th>Tags</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              <% cat.items.forEach(item => { %>
              <tr>
                <td>
                  <% if (item.image_path) { %>
                    <img src="<%= item.image_path %>" alt="" style="width:60px;height:40px;object-fit:cover;border-radius:4px;">
                  <% } else { %>
                    <div style="width:60px;height:40px;background:#1A1A1A;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:18px;"><%= item.name.charAt(0) %></div>
                  <% } %>
                </td>
                <td><%= item.name %></td>
                <td>Rs. <%= Math.round(item.base_price) %></td>
                <td><%= item.discount_enabled ? (item.discount_type === 'percentage' ? item.discount_value + '%' : 'Rs.' + item.discount_value) : '-' %></td>
                <td><% if (item.tags && item.tags.length) { %><% item.tags.forEach(t => { %><span class="tag"><%= t %></span><% }); %><% } %></td>
                <td><%= item.available ? '✅' : '❌' %></td>
                <td>
                  <div style="display:flex;gap:4px;flex-wrap:wrap;">
                    <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;" onclick="editItem(<%= item.id %>)">Edit</button>
                    <form method="POST" action="/stella-control/menu/item/toggle/<%= item.id %>" style="display:inline;">
                      <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;"><%= item.visible ? 'Hide' : 'Show' %></button>
                    </form>
                    <form method="POST" action="/stella-control/menu/item/duplicate/<%= item.id %>" style="display:inline;">
                      <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;">Duplicate</button>
                    </form>
                    <form method="POST" action="/stella-control/menu/item/delete/<%= item.id %>" style="display:inline;" onsubmit="return confirm('Delete this item?')">
                      <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Edit Item Modal -->
        <div class="modal" id="editModal<%= cat.id %>" style="display:none;">
          <div class="modal__overlay" onclick="closeEdit()"></div>
          <div class="modal__content">
            <h3>Edit Item</h3>
            <form method="POST" action="/stella-control/menu/item/update/<%= cat.items[0]?.id || 0 %>" enctype="multipart/form-data" id="editForm">
              <div class="form-group">
                <label>Name</label>
                <input type="text" name="name" class="input" id="editName" required>
              </div>
              <div class="form-group">
                <label>Description</label>
                <textarea name="description" class="input" rows="2" id="editDesc"></textarea>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label>Base Price</label>
                  <input type="number" name="base_price" class="input" step="0.01" id="editPrice">
                </div>
                <div class="form-group">
                  <label>Original Price</label>
                  <input type="number" name="original_price" class="input" step="0.01" id="editOrigPrice">
                </div>
              </div>
              <div class="form-group">
                <label>Image</label>
                <div class="image-upload-zone" id="editImagePreview" onclick="document.getElementById('editImageInput').click()">
                  <span>Click to upload or drag image here</span>
                </div>
                <input type="file" name="image" id="editImageInput" accept="image/jpeg,image/png,image/webp" style="display:none;" onchange="previewEditImage(event)">
                <div style="margin-top:8px;">
                  <label><input type="checkbox" name="remove_image" value="1"> Remove current image</label>
                </div>
              </div>
              <div class="form-group">
                <label>Tags</label>
                <div class="tag-checkboxes" id="editTags"></div>
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label><input type="checkbox" name="is_new" id="editIsNew"> Mark as New</label>
                </div>
                <div class="form-group">
                  <label><input type="checkbox" name="available" id="editAvailable" checked> Available</label>
                </div>
                <div class="form-group">
                  <label><input type="checkbox" name="visible" id="editVisible" checked> Visible</label>
                </div>
              </div>
              <div class="form-group">
                <label>Kitchen Notes</label>
                <input type="text" name="kitchen_notes" class="input" id="editNotes">
              </div>
              <div class="form-group">
                <label>Display Order</label>
                <input type="number" name="display_order" class="input" id="editOrder">
              </div>
              <button class="btn btn--gold">Save Changes</button>
              <button type="button" class="btn btn--outline" onclick="closeEdit()">Cancel</button>
            </form>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
  <script src="/js/admin/admin-main.js"></script>
  <script src="/js/admin/menu-manager.js"></script>
  <script src="/js/admin/image-upload.js"></script>
</body>
</html>
