<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Opening Hours</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/hours/save" class="admin-form">
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead><tr><th>Day</th><th>Open Time</th><th>Close Time</th><th>Closed</th></tr></thead>
          <tbody>
            <% hours.forEach(h => { %>
            <tr>
              <td><strong><%= h.day_name %></strong></td>
              <td><input type="time" name="open_<%= h.id %>" class="input" value="<%= h.open_time %>" style="width:auto;"></td>
              <td><input type="time" name="close_<%= h.id %>" class="input" value="<%= h.close_time %>" style="width:auto;"></td>
              <td><input type="checkbox" name="closed_<%= h.id %>" value="1" <%= h.is_closed ? 'checked' : '' %>></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <button class="btn btn--gold">Save Hours</button>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
