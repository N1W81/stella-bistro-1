<%- include('partials/admin-head') %>
<body class="admin-login-body">
  <div class="admin-login">
    <div class="admin-login__card">
      <div class="admin-login__logo">STELLA BISTRO</div>
      <p class="admin-login__subtitle">Admin Panel</p>

      <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
        <% success_msg.forEach(msg => { %><div class="flash flash--success"><%= msg %></div><% }); %>
      <% } %>
      <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
        <% error_msg.forEach(msg => { %><div class="flash flash--error"><%= msg %></div><% }); %>
      <% } %>

      <div class="admin-login__tabs">
        <button class="admin-login__tab admin-login__tab--active" data-tab="login" onclick="switchTab('login')">Login</button>
        <% if (typeof registrationOpen !== 'undefined' && registrationOpen) { %>
        <button class="admin-login__tab" data-tab="register" onclick="switchTab('register')">Create Account</button>
        <% } %>
      </div>

      <!-- Login Form -->
      <form class="admin-login__form" id="loginForm" action="/stella-control/login" method="POST">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" class="input" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="password-input">
            <input type="password" id="password" name="password" class="input" required>
            <button type="button" class="password-toggle" onclick="togglePassword('password', this)">👁️</button>
          </div>
        </div>
        <div class="form-group">
          <label class="checkbox-label">
            <input type="checkbox" name="remember" value="1">
            <span>Remember me (30 days)</span>
          </label>
        </div>
        <button type="submit" class="btn btn--gold" style="width:100%;">Login</button>
      </form>

      <!-- Register Form -->
      <% if (typeof registrationOpen !== 'undefined' && registrationOpen) { %>
      <form class="admin-login__form" id="registerForm" action="/stella-control/register" method="POST" style="display:none;">
        <div class="form-group">
          <label for="reg_username">Username</label>
          <input type="text" id="reg_username" name="username" class="input" required>
        </div>
        <div class="form-group">
          <label for="reg_password">Password</label>
          <div class="password-input">
            <input type="password" id="reg_password" name="password" class="input" required>
            <button type="button" class="password-toggle" onclick="togglePassword('reg_password', this)">👁️</button>
          </div>
        </div>
        <div class="form-group">
          <label for="reg_confirm">Confirm Password</label>
          <input type="password" id="reg_confirm" name="confirm_password" class="input" required>
        </div>
        <div class="form-group">
          <label for="secret_key">Secret Key</label>
          <input type="password" id="secret_key" name="secret_key" class="input" required placeholder="Enter admin secret key">
        </div>
        <button type="submit" class="btn btn--gold" style="width:100%;">Create Account</button>
      </form>
      <% } %>
    </div>
  </div>

  <script>
    function switchTab(tab) {
      document.querySelectorAll('.admin-login__tab').forEach(t => t.classList.remove('admin-login__tab--active'));
      document.querySelector(`.admin-login__tab[data-tab="${tab}"]`).classList.add('admin-login__tab--active');
      document.getElementById('loginForm').style.display = tab === 'login' ? '' : 'none';
      const regForm = document.getElementById('registerForm');
      if (regForm) regForm.style.display = tab === 'register' ? '' : 'none';
    }

    function togglePassword(id, btn) {
      const input = document.getElementById(id);
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.textContent = input.type === 'password' ? '👁️' : '👁️‍🗨️';
    }
  </script>
</body>
</html>
