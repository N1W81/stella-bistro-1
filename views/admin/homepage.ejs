<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Homepage Content</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <form method="POST" action="/stella-control/homepage/save" enctype="multipart/form-data" class="admin-form">
      <div class="admin-section">
        <h2>Hero Section</h2>
        <div class="form-group"><label>Hero Background Image</label><input type="file" name="hero_image" accept="image/*" class="input"><% if(settings.hero_image) {%><div style="margin-top:4px;"><img src="<%= settings.hero_image %>" style="max-width:200px;border-radius:4px;"></div><% } %></div>
        <div class="form-group"><label>Hero Tagline</label><input type="text" name="hero_tagline" class="input" value="<%= settings.hero_tagline || '' %>"></div>
      </div>
      <div class="admin-section">
        <h2>About Section</h2>
        <div class="form-group"><label>About Image</label><input type="file" name="about_image" accept="image/*" class="input"><% if(settings.about_image) {%><div style="margin-top:4px;"><img src="<%= settings.about_image %>" style="max-width:200px;border-radius:4px;"></div><% } %></div>
        <div class="form-group"><label>About Text</label><textarea name="about_text" class="input" rows="4"><%= settings.about_text || '' %></textarea></div>
        <div class="form-group"><label>Pull Quote</label><input type="text" name="pull_quote" class="input" value="<%= settings.pull_quote || '' %>"></div>
        <div class="form-group"><label>Signature Text</label><input type="text" name="signature_text" class="input" value="<%= settings.signature_text || '' %>"></div>
      </div>
      <div class="admin-section">
        <h2>Why Stella — Features</h2>
        <% for(let i = 1; i <= 4; i++) { %>
        <div class="admin-subsection">
          <h3>Feature <%= i %></h3>
          <div class="form-row">
            <div class="form-group"><label>Icon</label><select name="feature_<%= i %>_icon" class="input"><option value="flame" <%= settings['feature_'+i+'_icon'] === 'flame' ? 'selected' : '' %>>🔥 Flame</option><option value="star" <%= settings['feature_'+i+'_icon'] === 'star' ? 'selected' : '' %>>⭐ Star</option><option value="truck" <%= settings['feature_'+i+'_icon'] === 'truck' ? 'selected' : '' %>>🚚 Truck</option><option value="shield" <%= settings['feature_'+i+'_icon'] === 'shield' ? 'selected' : '' %>>🛡️ Shield</option></select></div>
            <div class="form-group"><label>Title</label><input type="text" name="feature_<%= i %>_title" class="input" value="<%= settings['feature_'+i+'_title'] || '' %>"></div>
          </div>
          <div class="form-group"><label>Description</label><input type="text" name="feature_<%= i %>_desc" class="input" value="<%= settings['feature_'+i+'_desc'] || '' %>"></div>
        </div>
        <% } %>
      </div>
      <button class="btn btn--gold">Save All Changes</button>
    </form>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
