<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Gallery</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <div class="admin-section">
      <h2>Upload Images</h2>
      <form method="POST" action="/stella-control/gallery/upload" enctype="multipart/form-data">
        <input type="file" name="images" multiple accept="image/*" class="input" required>
        <button class="btn btn--gold" style="margin-top:8px;">Upload</button>
      </form>
    </div>
    <div class="admin-section">
      <h2>All Images</h2>
      <div class="gallery-grid">
        <% images.forEach(img => { %>
        <div class="gallery-admin-item">
          <img src="<%= img.path %>" alt="<%= img.caption || '' %>">
          <div class="gallery-admin-item__overlay">
            <form method="POST" action="/stella-control/gallery/update/<%= img.id %>" class="gallery-admin-item__form">
              <input type="text" name="caption" value="<%= img.caption || '' %>" placeholder="Caption" class="input" style="font-size:12px;padding:4px 8px;">
              <input type="number" name="display_order" value="<%= img.display_order %>" class="input" style="width:50px;font-size:12px;padding:4px 8px;">
              <button class="btn btn--outline" style="padding:4px 8px;font-size:11px;">Save</button>
            </form>
            <form method="POST" action="/stella-control/gallery/delete/<%= img.id %>" onsubmit="return confirm('Delete this image?')">
              <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
            </form>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
