<%- include('partials/admin-head') %>
<body class="admin-body"><%- include('partials/admin-sidebar') %>
<div class="admin-main">
  <header class="admin-topbar"><button class="admin-topbar__hamburger" id="sidebarToggle">☰</button><h1>Settings</h1><div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div></header>
  <div class="admin-content">
    <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %><% success_msg.forEach(m => { %><div class="flash flash--success"><%= m %></div><% }); %><% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %><% error_msg.forEach(m => { %><div class="flash flash--error"><%= m %></div><% }); %><% } %>

    <form method="POST" action="/stella-control/settings/update" class="admin-form">
      <div class="admin-section">
        <h2>Site Settings</h2>
        <div class="form-row">
          <div class="form-group"><label>Site Name</label><input type="text" name="site_name" class="input" value="<%= settings.site_name || 'Stella Bistro' %>"></div>
          <div class="form-group"><label>Meta Description</label><input type="text" name="meta_description" class="input" value="<%= settings.meta_description || '' %>"></div>
        </div>
      </div>
      <div class="admin-section">
        <h2>Registration Control</h2>
        <div class="form-group">
          <label><input type="checkbox" name="registration_open" value="1" <%= settings.registration_open === '1' ? 'checked' : '' %>> Registration Open (unchecked = Login Only)</label>
        </div>
        <div class="form-group"><label>Admin Secret Key (for registration)</label><input type="text" name="admin_secret_key" class="input" value="<%= settings.admin_secret_key || process.env.ADMIN_SECRET_KEY || '' %>"></div>
      </div>
      <button class="btn btn--gold">Save Settings</button>
    </form>

    <div class="admin-section">
      <h2>Change Password</h2>
      <form method="POST" action="/stella-control/settings/change-password" class="admin-form" style="max-width:400px;">
        <div class="form-group"><label>Current Password</label><input type="password" name="current_password" class="input" required></div>
        <div class="form-group"><label>New Password</label><input type="password" name="new_password" class="input" required></div>
        <div class="form-group"><label>Confirm New Password</label><input type="password" name="confirm_password" class="input" required></div>
        <button class="btn btn--gold">Change Password</button>
      </form>
    </div>

    <div class="admin-section">
      <h2>Admin Accounts</h2>
      <div class="admin-table-wrapper">
        <table class="admin-table">
          <thead><tr><th>Username</th><th>Created</th><th>Last Login</th><th>Actions</th></tr></thead>
          <tbody>
            <% admins.forEach(a => { %>
            <tr>
              <td><%= a.username %></td>
              <td><%= a.created_at %></td>
              <td><%= a.last_login || 'Never' %></td>
              <td>
                <% if (a.id !== session.adminId) { %>
                <form method="POST" action="/stella-control/settings/delete-admin/<%= a.id %>" onsubmit="return confirm('Delete this admin?')">
                  <button class="btn btn--danger" style="padding:4px 8px;font-size:11px;">Delete</button>
                </form>
                <% } else { %>
                  <span style="color:var(--text-secondary);font-size:12px;">(you)</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-section">
      <h2>Custom CSS</h2>
      <form method="POST" action="/stella-control/settings/save-css">
        <textarea name="custom_css" class="input" rows="6" style="font-family:monospace;font-size:13px;"><%= settings.custom_css || '' %></textarea>
        <button class="btn btn--gold" style="margin-top:8px;">Save CSS</button>
      </form>
    </div>

    <div class="admin-section admin-section--danger">
      <h2>⚠️ Danger Zone</h2>
      <button class="btn btn--danger" onclick="if(confirm('Clear ALL orders? This cannot be undone.')){fetch('/stella-control/settings/clear-orders',{method:'POST'}).then(r=>r.json()).then(d=>alert(d.message))}">Clear All Test Orders</button>
      <button class="btn btn--danger" onclick="if(confirm('This will delete ALL data and reset to defaults. Continue?')){if(confirm('Are you sure? All menu items, orders, events, etc. will be lost.')){if(confirm('FINAL WARNING: This cannot be undone!')){fetch('/stella-control/settings/reset-defaults',{method:'POST'}).then(r=>r.json()).then(d=>alert(d.message))}}}">Reset to Defaults</button>
    </div>
  </div>
</div>
<script src="/js/admin/admin-main.js"></script>
</body>
</html>
