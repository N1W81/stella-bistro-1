<%- include('partials/admin-head') %>
<body class="admin-body">
  <%- include('partials/admin-sidebar') %>
  <div class="admin-main">
    <header class="admin-topbar">
      <button class="admin-topbar__hamburger" id="sidebarToggle">☰</button>
      <h1 class="admin-topbar__title">Pricing & Discounts</h1>
      <div class="admin-topbar__actions"><span><%= adminUsername %></span><a href="/stella-control/logout" class="admin-topbar__logout">Logout</a></div>
    </header>
    <div class="admin-content">
      <div class="admin-section">
        <h2>Bulk Actions</h2>
        <div class="bulk-actions">
          <select id="bulkCategory" class="input" style="width:auto;">
            <option value="">Select Category</option>
            <% menuData.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }); %>
          </select>
          <select id="bulkDiscountType" class="input" style="width:auto;">
            <option value="percentage">Percentage %</option>
            <option value="fixed">Fixed Rs.</option>
          </select>
          <input type="number" id="bulkDiscountValue" class="input" style="width:100px;" placeholder="Value" step="0.01">
          <button class="btn btn--gold" onclick="applyBulkDiscount()">Apply to Category</button>
          <button class="btn btn--danger" onclick="removeAllDiscounts()">Remove All Discounts</button>
        </div>
      </div>

      <% menuData.forEach(cat => { %>
      <div class="admin-section">
        <h2><%= cat.name %></h2>
        <div class="admin-table-wrapper">
          <table class="admin-table pricing-table">
            <thead><tr><th>Item</th><th>Base Price</th><th>Orig. Price</th><th>Discount</th><th>Type</th><th>Value</th><th>Final Price</th></tr></thead>
            <tbody>
              <% cat.items.forEach(item => { %>
              <tr class="pricing-row" data-id="<%= item.id %>">
                <td><%= item.name %></td>
                <td><input type="number" class="input pricing-input" name="base_price" value="<%= item.base_price %>" step="0.01"></td>
                <td><input type="number" class="input pricing-input" name="original_price" value="<%= item.original_price || item.base_price %>" step="0.01"></td>
                <td><input type="checkbox" class="pricing-toggle" <%= item.discount_enabled ? 'checked' : '' %>></td>
                <td>
                  <select class="input pricing-input pricing-type" style="width:auto;">
                    <option value="percentage" <%= item.discount_type === 'percentage' ? 'selected' : '' %>>%</option>
                    <option value="fixed" <%= item.discount_type === 'fixed' ? 'selected' : '' %>>Rs.</option>
                  </select>
                </td>
                <td><input type="number" class="input pricing-input pricing-value" value="<%= item.discount_value || 0 %>" step="0.01" style="width:80px;"></td>
                <td class="pricing-final gold">Rs. <%= Math.round(item.display_price || item.base_price) %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <% }); %>
      <button class="btn btn--gold" onclick="savePricing()">Save All Changes</button>
    </div>
  </div>
  <script src="/js/admin/admin-main.js"></script>
  <script>
    function savePricing() {
      const items = [];
      document.querySelectorAll('.pricing-row').forEach(row => {
        items.push({
          id: row.dataset.id,
          base_price: row.querySelector('[name="base_price"]').value,
          original_price: row.querySelector('[name="original_price"]').value,
          discount_enabled: row.querySelector('.pricing-toggle').checked,
          discount_type: row.querySelector('.pricing-type').value,
          discount_value: row.querySelector('.pricing-value').value,
        });
      });
      fetch('/stella-control/pricing/bulk-update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items }),
      }).then(r => r.json()).then(d => { if(d.success) location.reload(); });
    }
    function applyBulkDiscount() {
      const category_id = document.getElementById('bulkCategory').value;
      const discount_type = document.getElementById('bulkDiscountType').value;
      const discount_value = document.getElementById('bulkDiscountValue').value;
      if (!category_id) return alert('Select a category');
      fetch('/stella-control/pricing/category-discount', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category_id, discount_type, discount_value }),
      }).then(r => r.json()).then(d => { if(d.success) location.reload(); });
    }
    function removeAllDiscounts() {
      if (!confirm('Remove all discounts?')) return;
      fetch('/stella-control/pricing/remove-all', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      }).then(r => r.json()).then(d => { if(d.success) location.reload(); });
    }
  </script>
</body>
</html>
