<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="events-page">
    <div class="events-page__header">
      <h1>Events at Stella</h1>
    </div>

    <div class="events-page__grid">
      <% if (typeof events !== 'undefined' && events.length > 0) { %>
        <% events.forEach(e => { %>
        <div class="event-card">
          <div class="event-card__image" style="background-image: url('<%= e.image_path || 'https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?w=600&q=80' %>');">
            <span class="event-card__date"><%= new Date(e.date).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'}) %></span>
          </div>
          <div class="event-card__body">
            <% if (e.time) { %><span class="event-card__time"><%= e.time %></span><% } %>
            <h3><%= e.title %></h3>
            <p><%= e.description || '' %></p>
          </div>
        </div>
        <% }); %>
      <% } else { %>
        <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">No upcoming events. Stay tuned! 🎉</p>
      <% } %>
    </div>

    <!-- Pagination -->
    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
    <div class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/events?page=<%= i %>" class="pagination__link <%= i === currentPage ? 'pagination__link--active' : '' %>"><%= i %></a>
      <% } %>
    </div>
    <% } %>

    <!-- Past Events -->
    <% if (typeof pastEvents !== 'undefined' && pastEvents.length > 0) { %>
    <div class="events-page__past">
      <button class="events-page__toggle" onclick="this.nextElementSibling.classList.toggle('open');this.textContent=this.nextElementSibling.classList.contains('open')?'Hide Past Events':'Show Past Events'">
        Show Past Events
      </button>
      <div class="events-page__past-grid" style="display:none;">
        <% pastEvents.forEach(e => { %>
        <div class="event-card event-card--past">
          <div class="event-card__body">
            <span class="event-card__time"><%= new Date(e.date).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'}) %></span>
            <h3><%= e.title %></h3>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
