<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main>
    <!-- Hero Section -->
    <section class="hero" id="hero" style="background-image: url('<%= (typeof settings !== 'undefined' && settings.hero_image) || 'https://images.unsplash.com/photo-1555396273-367ea4eb4db5?w=1920&q=80' %>');">
      <div class="hero__overlay"></div>
      <div class="hero__content">
        <span class="hero__eyebrow">KARACHI'S FINEST BISTRO</span>
        <h1 class="hero__title">STELLA BISTRO</h1>
        <p class="hero__tagline"><%= (typeof settings !== 'undefined' && settings.hero_tagline) || 'Where Every Plate Tells a Story' %></p>
        <div class="hero__actions">
          <a href="/menu" class="btn btn--gold">Order Now</a>
          <a href="/menu" class="btn btn--ghost">View Menu</a>
        </div>
      </div>
      <div class="hero__badge">
        <svg viewBox="0 0 200 200" width="120" height="120">
          <defs>
            <path id="circlePath" d="M 100, 100 m -75, 0 a 75,75 0 1,1 150,0 a 75,75 0 1,1 -150,0" />
          </defs>
          <circle cx="100" cy="100" r="75" fill="none" stroke="#C9A84C" stroke-width="1" opacity="0.3"/>
          <text font-family="DM Sans" font-size="10" fill="#C9A84C" letter-spacing="3" opacity="0.8">
            <textPath href="#circlePath" startOffset="0%">EST. · KARACHI, PAKISTAN · </textPath>
          </text>
          <circle cx="100" cy="100" r="4" fill="#C9A84C" opacity="0.8"/>
        </svg>
      </div>
      <div class="hero__scroll">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F5F0E8" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
      </div>
    </section>

    <!-- Promo Ticker -->
    <% if (typeof settings !== 'undefined' && settings.ticker_enabled === '1' && settings.ticker_text) { %>
    <div class="ticker">
      <div class="ticker__inner">
        <span><%= settings.ticker_text %></span>
        <span><%= settings.ticker_text %></span>
      </div>
    </div>
    <% } %>

    <!-- Our Story -->
    <section class="section story" id="story">
      <div class="story__grid">
        <div class="story__image" style="background-image: url('<%= (typeof settings !== 'undefined' && settings.about_image) || 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80' %>');"></div>
        <div class="story__content">
          <span class="section__eyebrow">SINCE 2024</span>
          <h2 class="section__title">Our Story</h2>
          <p class="story__text"><%= (typeof settings !== 'undefined' && settings.about_text) || 'Stella Bistro was born from a passion for exceptional food and intimate dining.' %></p>
          <blockquote class="story__quote">"<%= (typeof settings !== 'undefined' && settings.pull_quote) || 'Food is the language we all speak.' %>"</blockquote>
          <p class="story__signature"><%= (typeof settings !== 'undefined' && settings.signature_text) || '— The Stella Team' %></p>
        </div>
      </div>
    </section>

    <!-- Why Stella -->
    <section class="section features">
      <div class="features__grid">
        <% const features = [
          { icon: 'flame', title: 'Fresh Ingredients', desc: 'Every dish made with hand-selected, quality ingredients' },
          { icon: 'star', title: 'Signature Recipes', desc: 'Unique recipes crafted by our expert chefs' },
          { icon: 'truck', title: 'Fast Delivery', desc: 'Hot food at your door in 30–45 minutes' },
          { icon: 'shield', title: '100% Halal', desc: 'All our ingredients are certified halal' },
        ];
        features.forEach((f, i) => {
          const fi = i + 1;
          const title = (typeof settings !== 'undefined' && settings[`feature_${fi}_title`]) || f.title;
          const desc = (typeof settings !== 'undefined' && settings[`feature_${fi}_desc`]) || f.desc;
        %>
        <div class="feature-card">
          <div class="feature-card__icon">
            <% if (f.icon === 'flame') { %>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="#C9A84C"><path d="M8.5 14.5A2.5 2.5 0 0011 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 11-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 002.5 2.5z"/></svg>
            <% } else if (f.icon === 'star') { %>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="#C9A84C"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <% } else if (f.icon === 'truck') { %>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <% } else { %>
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <% } %>
          </div>
          <h3 class="feature-card__title"><%= title %></h3>
          <p class="feature-card__desc"><%= desc %></p>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Featured Dishes -->
    <section class="section featured" id="featured">
      <div class="section__header">
        <h2 class="section__title">Our Signatures</h2>
        <p class="section__subtitle">Dishes that define us</p>
      </div>
      <div class="featured__grid">
        <% if (typeof featured !== 'undefined' && featured.length > 0) { %>
          <% featured.forEach(item => { %>
          <div class="dish-card" onclick="event.stopPropagation();">
            <div class="dish-card__image">
              <% if (item.image_path) { %>
                <img src="<%= item.image_path %>" alt="<%= item.name %>" loading="lazy">
              <% } else { %>
                <div class="dish-card__placeholder"><%= item.name.charAt(0) %></div>
              <% } %>
              <% if (item.discount_enabled && item.discount_value > 0) { %>
                <span class="dish-card__badge dish-card__badge--discount"><%= item.discount_type === 'percentage' ? item.discount_value + '% OFF' : 'Rs.' + item.discount_value + ' OFF' %></span>
              <% } %>
              <% if (item.is_new) { %>
                <span class="dish-card__badge dish-card__badge--new">NEW</span>
              <% } %>
            </div>
            <div class="dish-card__body">
              <h3 class="dish-card__name"><%= item.name %></h3>
              <p class="dish-card__desc"><%= item.description || '' %></p>
              <div class="dish-card__price-row">
                <% if (item.discount_enabled && item.original_price > item.base_price) { %>
                  <span class="dish-card__price-original">Rs. <%= Math.round(item.original_price) %></span>
                <% } %>
                <span class="dish-card__price">Rs. <%= Math.round(item.display_price || item.base_price) %></span>
              </div>
              <button class="btn btn--outline dish-card__add" data-id="<%= item.id %>" data-name="<%= item.name.replace(/'/g, "\\'") %>" data-price="<%= Math.round(item.display_price || item.base_price) %>" data-image="<%= item.image_path || '' %>">Add to Cart</button>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">No featured dishes yet. Admin can feature dishes from the admin panel.</p>
        <% } %>
      </div>
    </section>

    <!-- Testimonials -->
    <section class="section testimonials" id="testimonials">
      <div class="section__header">
        <h2 class="section__title">What Our Guests Say</h2>
      </div>
      <div class="testimonials__carousel" id="testimonialsCarousel">
        <div class="testimonials__track" id="testimonialsTrack">
          <% if (typeof testimonials !== 'undefined' && testimonials.length > 0) { %>
            <% testimonials.forEach(t => { %>
            <div class="testimonial-card">
              <div class="testimonial-card__quote">"</div>
              <p class="testimonial-card__text"><%= t.review_text %></p>
              <div class="testimonial-card__stars">
                <% for(let i = 0; i < 5; i++) { %>
                  <span class="star <%= i < t.rating ? 'star--filled' : '' %>">★</span>
                <% } %>
              </div>
              <p class="testimonial-card__name">— <%= t.reviewer_name %></p>
              <p class="testimonial-card__date"><%= t.review_date %></p>
            </div>
            <% }); %>
          <% } else { %>
            <div class="testimonial-card">
              <div class="testimonial-card__quote">"</div>
              <p class="testimonial-card__text">Amazing food and service! Highly recommend.</p>
              <div class="testimonial-card__stars">
                <span class="star star--filled">★</span><span class="star star--filled">★</span><span class="star star--filled">★</span><span class="star star--filled">★</span><span class="star star--filled">★</span>
              </div>
              <p class="testimonial-card__name">— Our Guest</p>
            </div>
          <% } %>
        </div>
        <div class="testimonials__dots" id="testimonialsDots"></div>
      </div>
    </section>

    <!-- Events Preview -->
    <section class="section events-preview" id="events">
      <div class="section__header">
        <h2 class="section__title">What's On at Stella</h2>
      </div>
      <div class="events-preview__grid">
        <% if (typeof upcomingEvents !== 'undefined' && upcomingEvents.length > 0) { %>
          <% upcomingEvents.forEach(e => { %>
          <div class="event-card">
            <div class="event-card__image" style="background-image: url('<%= e.image_path || 'https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?w=600&q=80' %>');">
              <span class="event-card__date"><%= new Date(e.date).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'}) %></span>
            </div>
            <div class="event-card__body">
              <h3><%= e.title %></h3>
              <p><%= (e.description || '').substring(0, 120) %></p>
            </div>
          </div>
          <% }); %>
        <% } else { %>
          <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">Stay tuned for upcoming events! 🎉</p>
        <% } %>
      </div>
      <% if (typeof upcomingEvents !== 'undefined' && upcomingEvents.length > 0) { %>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/events" class="btn btn--ghost">View All Events →</a>
      </div>
      <% } %>
    </section>

    <!-- News Preview -->
    <section class="section news-preview" id="news">
      <div class="section__header">
        <h2 class="section__title">Latest from Stella</h2>
      </div>
      <div class="news-preview__grid">
        <% if (typeof newsPosts !== 'undefined' && newsPosts.length > 0) { %>
          <% newsPosts.forEach(post => { %>
          <a href="/news/<%= post.slug %>" class="news-card">
            <div class="news-card__image" style="background-image: url('<%= post.thumbnail || 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80' %>');"></div>
            <div class="news-card__body">
              <span class="news-card__date"><%= post.date %></span>
              <h3><%= post.title %></h3>
              <p><%= (post.excerpt || '').substring(0, 120) %></p>
              <span class="news-card__more">Read More →</span>
            </div>
          </a>
          <% }); %>
        <% } else { %>
          <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">No news yet. Stay tuned!</p>
        <% } %>
      </div>
      <% if (typeof newsPosts !== 'undefined' && newsPosts.length > 0) { %>
      <div style="text-align:center;margin-top:2rem;">
        <a href="/news" class="btn btn--ghost">See All News →</a>
      </div>
      <% } %>
    </section>

    <!-- Gallery -->
    <section class="section gallery" id="gallery">
      <div class="section__header">
        <h2 class="section__title">The Stella Experience</h2>
      </div>
      <div class="gallery__grid">
        <% if (typeof galleryImages !== 'undefined' && galleryImages.length > 0) { %>
          <% galleryImages.forEach(img => { %>
          <div class="gallery__item" onclick="openLightbox('<%= img.path %>', '<%= (img.caption || '').replace(/'/g, "\\'") %>')">
            <img src="<%= img.path %>" alt="<%= img.caption || 'Gallery' %>" loading="lazy">
            <% if (img.caption) { %><span class="gallery__caption"><%= img.caption %></span><% } %>
          </div>
          <% }); %>
        <% } else { %>
          <p style="grid-column:1/-1;text-align:center;color:var(--text-secondary);padding:3rem 0;">Gallery coming soon!</p>
        <% } %>
      </div>
    </section>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" onclick="closeLightbox(event)">
      <button class="lightbox__close" onclick="closeLightbox()">&times;</button>
      <button class="lightbox__nav lightbox__nav--prev" onclick="navigateLightbox(-1)">‹</button>
      <img class="lightbox__img" id="lightboxImg" alt="">
      <p class="lightbox__caption" id="lightboxCaption"></p>
      <button class="lightbox__nav lightbox__nav--next" onclick="navigateLightbox(1)">›</button>
    </div>

    <!-- Timings -->
    <section class="section timings" id="timings">
      <div class="section__header">
        <h2 class="section__title">When to Find Us</h2>
        <p class="section__subtitle">We're here to serve you</p>
      </div>
      <div class="timings__status">
        <% if (typeof openNow !== 'undefined' && openNow) { %>
          <span class="status-dot status-dot--open"></span> Open Now
        <% } else { %>
          <span class="status-dot status-dot--closed"></span> Closed
        <% } %>
      </div>
      <div class="timings__table">
        <% if (typeof hours !== 'undefined' && hours.length > 0) { %>
          <% hours.forEach(h => { %>
          <div class="timings__row">
            <span class="timings__day"><%= h.day_name %></span>
            <span class="timings__time <%= h.is_closed ? 'timings__time--closed' : '' %>"><%= h.is_closed ? 'Closed' : h.open_time + ' – ' + h.close_time %></span>
          </div>
          <% }); %>
        <% } %>
      </div>
    </section>

    <!-- Location -->
    <section class="section location" id="location">
      <div class="location__grid">
        <div class="location__info">
          <h2 class="section__title">Find Us</h2>
          <% if (typeof settings !== 'undefined' && settings.address) { %>
            <p class="location__detail"><%= settings.address %></p>
          <% } %>
          <% if (typeof settings !== 'undefined' && settings.phone) { %>
            <p class="location__detail"><a href="tel:<%= settings.phone.replace(/[^0-9+]/g,'') %>" class="location__link"><%= settings.phone %></a></p>
          <% } %>
          <% if (typeof settings !== 'undefined' && settings.email) { %>
            <p class="location__detail"><a href="mailto:<%= settings.email %>" class="location__link"><%= settings.email %></a></p>
          <% } %>
          <% if (typeof settings !== 'undefined' && settings.whatsapp_number) { %>
            <a href="https://wa.me/<%= settings.whatsapp_number %>" target="_blank" class="btn btn--gold" style="margin-top:1rem;">Chat on WhatsApp</a>
          <% } %>
          <div class="location__social">
            <% if (typeof settings !== 'undefined' && settings.instagram_url) { %>
              <a href="<%= settings.instagram_url %>" target="_blank" rel="noopener">Instagram</a>
            <% } %>
            <% if (typeof settings !== 'undefined' && settings.facebook_url) { %>
              <a href="<%= settings.facebook_url %>" target="_blank" rel="noopener">Facebook</a>
            <% } %>
          </div>
          <% if (typeof settings !== 'undefined' && settings.maps_directions_url) { %>
            <a href="<%= settings.maps_directions_url %>" target="_blank" class="btn btn--ghost" style="margin-top:1rem;">Get Directions →</a>
          <% } %>
        </div>
        <div class="location__map">
          <% if (typeof settings !== 'undefined' && settings.maps_embed_url) { %>
            <iframe src="<%= settings.maps_embed_url %>" width="100%" height="100%" style="border:0;min-height:350px;" allowfullscreen loading="lazy"></iframe>
          <% } %>
        </div>
      </div>
    </section>

    <!-- Reservation -->
    <section class="section reservation" id="reservation">
      <div class="section__header">
        <h2 class="section__title">Book Your Table</h2>
      </div>
      <form class="reservation__form" id="reservationForm">
        <div class="reservation__grid">
          <div class="form-group">
            <label for="res_name">Full Name *</label>
            <input type="text" id="res_name" name="name" required>
          </div>
          <div class="form-group">
            <label for="res_phone">Phone Number *</label>
            <input type="tel" id="res_phone" name="phone" required pattern="[0-9+\-\s]+">
          </div>
          <div class="form-group">
            <label for="res_email">Email</label>
            <input type="email" id="res_email" name="email">
          </div>
          <div class="form-group">
            <label for="res_date">Date *</label>
            <input type="date" id="res_date" name="date" required>
          </div>
          <div class="form-group">
            <label for="res_time">Time *</label>
            <select id="res_time" name="time" required>
              <% for(let h = 11; h <= 23; h++) {
                for(let m = 0; m < 60; m += 30) {
                  const hour = h > 12 ? h - 12 : h;
                  const ampm = h >= 12 ? 'PM' : 'AM';
                  const timeStr = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
                  const display = `${hour}:${String(m).padStart(2,'0')} ${ampm}`;
              %>
              <option value="<%= timeStr %>"><%= display %></option>
              <% } } %>
            </select>
          </div>
          <div class="form-group">
            <label for="res_guests">Number of Guests *</label>
            <select id="res_guests" name="guests" required>
              <% for(let i = 1; i <= 20; i++) { %>
                <option value="<%= i %>"><%= i %></option>
              <% } %>
            </select>
          </div>
          <div class="form-group">
            <label for="res_occasion">Occasion</label>
            <select id="res_occasion" name="occasion">
              <option value="">None</option>
              <option value="Birthday">Birthday</option>
              <option value="Anniversary">Anniversary</option>
              <option value="Business">Business</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-group form-group--full">
            <label for="res_requests">Special Requests</label>
            <textarea id="res_requests" name="special_requests" rows="3"></textarea>
          </div>
        </div>
        <button type="submit" class="btn btn--gold reservation__submit">Reserve Now</button>
      </form>
      <div class="reservation__success" id="reservationSuccess" style="display:none;">
        <div class="reservation__success-icon">✓</div>
        <h3>Reservation Confirmed! 🎉</h3>
        <p>We'll see you soon at Stella Bistro.</p>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>

  <script>
    // Reservation form handler
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('reservationForm');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const data = new FormData(form);
          const body = {};
          data.forEach((v, k) => body[k] = v);

          try {
            const res = await fetch('/api/reservations', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body),
            });
            const result = await res.json();
            if (result.success) {
              form.style.display = 'none';
              document.getElementById('reservationSuccess').style.display = 'block';
              // Confetti effect
              const colors = ['#C9A84C', '#F5F0E8', '#6B1A2A', '#2ECC71'];
              for (let i = 0; i < 50; i++) {
                const el = document.createElement('div');
                el.style.cssText = `position:fixed;width:8px;height:8px;background:${colors[i%4]};border-radius:2px;top:-10px;left:${Math.random()*100}vw;z-index:9999;pointer-events:none;animation:confettiFall ${1+Math.random()}s linear forwards;animation-delay:${Math.random()*0.5}s`;
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 3000);
              }
            } else {
              alert(result.error || 'Something went wrong');
            }
          } catch(e) {
            alert('Network error. Please try again.');
          }
        });
      }

      // Set min date for reservation
      const dateInput = document.getElementById('res_date');
      if (dateInput) {
        dateInput.min = new Date().toISOString().split('T')[0];
      }
    });
  </script>

  <style>
    @keyframes confettiFall {
      0% { transform: translateY(0) rotate(0deg); opacity: 1; }
      100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
    }
  </style>
</body>
</html>
