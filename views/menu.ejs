<%- include('partials/head') %>
<body>
  <%- include('partials/flash') %>
  <%- include('partials/nav') %>

  <main class="menu-page">
    <!-- Category Tabs -->
    <div class="menu-tabs" id="menuTabs">
      <div class="menu-tabs__inner" id="menuTabsInner">
        <% if (typeof menuData !== 'undefined') { %>
          <% menuData.forEach(cat => { %>
            <button class="menu-tab" data-category="<%= cat.id %>" onclick="scrollToCategory(<%= cat.id %>)"><%= cat.name %></button>
          <% }); %>
        <% } %>
      </div>
    </div>

    <div class="menu-page__content">
      <!-- Search & Filters -->
      <div class="menu-toolbar">
        <div class="menu-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="menuSearch" placeholder="Search dishes..." oninput="filterMenu()">
        </div>
        <div class="menu-filters" id="menuFilters">
          <button class="filter-chip filter-chip--active" data-filter="all" onclick="setFilter('all', this)">All</button>
          <button class="filter-chip" data-filter="Spicy" onclick="setFilter('Spicy', this)">Spicy 🌶</button>
          <button class="filter-chip" data-filter="Vegetarian" onclick="setFilter('Vegetarian', this)">Veg 🌱</button>
          <button class="filter-chip" data-filter="Chef's Special" onclick="setFilter('Chef\'s Special', this)">Chef's Special ⭐</button>
          <button class="filter-chip" data-filter="Bestseller" onclick="setFilter('Bestseller', this)">Bestseller 🔥</button>
        </div>
      </div>

      <!-- Menu Sections -->
      <% if (typeof menuData !== 'undefined') { %>
        <% menuData.forEach(cat => { %>
          <% if (cat.items.length > 0) { %>
          <section class="menu-section" id="category-<%= cat.id %>" data-category="<%= cat.id %>">
            <div class="menu-section__header">
              <h2 class="section__title"><%= cat.name %></h2>
              <div class="section__rule"></div>
            </div>
            <div class="menu-section__grid">
              <% cat.items.forEach(item => { %>
              <div class="dish-card menu-item" data-name="<%= item.name.toLowerCase() %>" data-desc="<%= (item.description || '').toLowerCase() %>" data-tags='<%= JSON.stringify(item.tags || []) %>'>
                <div class="dish-card__image">
                  <% if (item.image_path) { %>
                    <img src="<%= item.image_path %>" alt="<%= item.name %>" loading="lazy">
                  <% } else { %>
                    <div class="dish-card__placeholder"><%= item.name.charAt(0) %></div>
                  <% } %>
                  <% if (item.discount_enabled && item.discount_value > 0) { %>
                    <span class="dish-card__badge dish-card__badge--discount">
                      <%= item.discount_type === 'percentage' ? item.discount_value + '% OFF' : 'Rs. ' + item.discount_value + ' OFF' %>
                    </span>
                  <% } %>
                  <% if (item.is_new) { %>
                    <span class="dish-card__badge dish-card__badge--new">NEW</span>
                  <% } %>
                </div>
                <div class="dish-card__body">
                  <h3 class="dish-card__name"><%= item.name %></h3>
                  <p class="dish-card__desc"><%= item.description || '' %></p>
                  <div class="dish-card__tags">
                    <% if (item.tags && item.tags.length > 0) { %>
                      <% item.tags.forEach(tag => { %>
                        <span class="dish-card__tag"><%= tag %></span>
                      <% }); %>
                    <% } %>
                  </div>
                  <div class="dish-card__price-row">
                    <% if (item.discount_enabled && item.original_price > item.base_price) { %>
                      <span class="dish-card__price-original">Rs. <%= Math.round(item.original_price) %></span>
                    <% } %>
                    <span class="dish-card__price">Rs. <%= Math.round(item.display_price || item.base_price) %></span>
                  </div>
                  <% if (item.available) { %>
                    <button class="btn btn--outline dish-card__add" data-id="<%= item.id %>" data-name="<%= item.name.replace(/'/g, "\\'") %>" data-price="<%= Math.round(item.display_price || item.base_price) %>" data-image="<%= item.image_path || '' %>">Add to Cart</button>
                  <% } else { %>
                    <button class="btn btn--disabled dish-card__add" disabled>Currently Unavailable</button>
                  <% } %>
                </div>
              </div>
              <% }); %>
            </div>
          </section>
          <% } %>
        <% }); %>
      <% } %>

      <!-- No results -->
      <div class="menu-no-results" id="noResults" style="display:none;">
        <p>No dishes found. Try a different keyword or filter.</p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/cart.js"></script>
  <script src="/js/menu.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
